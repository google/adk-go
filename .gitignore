# .gitignore is restricted to the artifacts produced by go build and test.
# for personal setup you can use personal .gitignore: `git config --global core.excludesfile ~/.gitignore`

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work
go.work.sum

# Stray binaries from running go build at repo root
/code_reviewer
/incident_responder
/pr_triage
/production_llm_agent
/qa_evaluator
/refund_approval
/research_assistant
/research_planner
/support_with_compaction
/travel_concierge
/content_pipeline
