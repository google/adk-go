# vLLM configuration for ADK Go OpenAI adapter
# Copy to .env and customize as needed: cp .env.example .env

# Model to serve (HuggingFace model ID)
VLLM_MODEL=Qwen/Qwen3.5-4B

# Port exposed on the host
VLLM_PORT=8000

# Maximum context length (reduce if running low on VRAM)
VLLM_MAX_MODEL_LEN=8192

# Fraction of GPU memory to use (0.0-1.0)
VLLM_GPU_MEM_UTIL=0.90

# MTP speculative decoding tokens (Qwen3.5 feature for faster inference)
VLLM_MTP_TOKENS=1

# HuggingFace token (optional, required for gated models)
HF_TOKEN=
